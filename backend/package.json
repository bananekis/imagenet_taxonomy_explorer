{
  "name": "imagenet-taxonomy-api",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/src/index.js",
    "ingest": "tsx scripts/ingest.ts",
    "ingest:prod": "node dist/scripts/ingest.js",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\" \"prisma/schema.prisma\""
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "fast-xml-parser": "^4.5.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "prettier": "^3.8.1",
    "prettier-plugin-prisma": "^5.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
